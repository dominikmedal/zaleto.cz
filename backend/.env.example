# ── Server ────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────
# Lokální vývoj:  ../data/zaleto.db
# Railway:        /data/zaleto.db  (persistent volume připojený na /data)
DATABASE_PATH=../data/zaleto.db

# ── External APIs ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
PEXELS_API_KEY=

# ── SMTP (scraper e-mailové reporty) ──────────────────────────────────────
SMTP_HOST=smtp.seznam.cz
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_TO=
REPORT_FROM=

# ── Scraper ───────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_H=12
SCRAPER_DELAY=1.5
